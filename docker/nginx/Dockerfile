FROM node:22-alpine AS build

WORKDIR /app

ARG VITE_APP_BACKEND_BASE_URL=http://localhost:8081
ARG VITE_SYMLINK_FOLDER=storage
ARG VITE_CLERK_PUBLISHABLE_KEY
ARG VITE_CLERK_SIGN_IN_URL=/login
ARG VITE_CLERK_SIGN_UP_URL=/register
ARG VITE_FEATURE_CLERK_PASSKEY=false
ARG VITE_FEATURE_CLERK_TOTP=false

ENV VITE_APP_BACKEND_BASE_URL=${VITE_APP_BACKEND_BASE_URL}
ENV VITE_SYMLINK_FOLDER=${VITE_SYMLINK_FOLDER}
ENV VITE_CLERK_PUBLISHABLE_KEY=${VITE_CLERK_PUBLISHABLE_KEY}
ENV VITE_CLERK_SIGN_IN_URL=${VITE_CLERK_SIGN_IN_URL}
ENV VITE_CLERK_SIGN_UP_URL=${VITE_CLERK_SIGN_UP_URL}
ENV VITE_FEATURE_CLERK_PASSKEY=${VITE_FEATURE_CLERK_PASSKEY}
ENV VITE_FEATURE_CLERK_TOTP=${VITE_FEATURE_CLERK_TOTP}

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:1.28-alpine AS runtime

COPY docker/nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
